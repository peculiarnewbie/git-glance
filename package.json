{
  "name": "git-glance",
  "private": true,
  "scripts": {
    "build:serve-go": "cd packages/server-go && go build -o ../../dist/git-glance-serve .",
    "build:agent": "cd packages/agent && go build -o ../../dist/git-glance-agent .",
    "build:cloudflare": "pnpm --filter @git-glance/desktop build && cp -r packages/desktop/dist/* packages/cloudflare/dist/",
    "deploy:cloudflare": "pnpm build:cloudflare && cd packages/cloudflare && wrangler deploy",
    "build:desktop": "cd packages/desktop && electrobun build --env=stable",
    "dev": "concurrently -n agent,vite \"go run ./packages/agent\" \"pnpm --filter @git-glance/desktop dev\"",
    "dev:agent": "go run ./packages/agent",
    "dev:ui": "pnpm --filter @git-glance/desktop dev",
    "dev:server-go": "go run ./packages/server-go"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
