{
  "name": "git-glance",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "dev": "concurrently \"pnpm --filter @git-glance/server dev\" \"pnpm --filter @git-glance/app dev\"",
    "dev:server": "pnpm --filter @git-glance/server dev",
    "dev:tui": "pnpm --filter @git-glance/tui dev",
    "dev:app": "pnpm --filter @git-glance/app dev"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
