    "types": "wrangler types"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.64",
    "@openauthjs/openauth": "^0.4.3",
    "alchemy": "2.0.0-beta.36",
    "effect": "4.0.0-beta.64",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250514.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.0.0"
  }
}
