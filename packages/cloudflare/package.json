{
  "name": "@git-glance/cloudflare",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "pnpm run build && alchemy deploy alchemy.run.ts",
    "deploy:wrangler": "wrangler deploy",
